{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "ServFlow Documentation",
  "colors": {
    "primary": "#8F0BC7",
    "light": "#bc60e3",
    "dark": "#550776"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["index", "installation", "quickstart", "development"]
          },
          {
            "group": "Concepts",
            "pages": [
              "references/concepts/actions",
              "references/concepts/conditionals"
            ]
          },
          {
            "group": "Actions",
            "pages": [
              "actions/overview",
              "actions/data-operations",
              "actions/vector-operations",
              "actions/http-requests",
              "actions/authentication",
              "actions/transformation",
              "actions/ai-agents",
              "actions/flow-control",
              "actions/communication",
              "actions/command",
              "actions/memory",
              "actions/binance"
            ]
          },
          {
            "group": "References",
            "pages": ["references/configuration", "references/secrets"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "hidden": true,
        "groups": [
          {
            "group": "API Documentation",
            "pages": ["api-reference/introduction"]
          },
          {
            "group": "Endpoint Examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/logo-new.svg",
    "dark": "/logo/logo-white.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:contact@servflow.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dash.servflow.io"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/servflow"
    }
  }
}
