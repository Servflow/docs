{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "ServFlow Documentation",
  "integrations": {
    "ga4": {
      "measurementId": "G-LCJ06LBSBY"
    }
  },
  "colors": {
    "primary": "#8F0BC7",
    "light": "#bc60e3",
    "dark": "#550776"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "installation",
              {
                "group": "Quickstart",
                "pages": [
                  "quickstart",
                  "quickstart-dashboard",
                  "quickstart-yaml"
                ]
              },
              "running-modes",
              "development"
            ]
          },

          {
            "group": "Concepts",
            "pages": [
              {
                "group": "Actions",
                "pages": [
                  "concepts/actions/overview",
                  {
                    "group": "Available Actions",
                    "pages": [
                      "concepts/actions/available",
                      "concepts/actions/data-operations",
                      "concepts/actions/vector-operations",
                      "concepts/actions/http-requests",
                      "concepts/actions/authentication",
                      "concepts/actions/transformation",
                      "concepts/actions/ai-agents",
                      "concepts/actions/flow-control",
                      "concepts/actions/communication",
                      "concepts/actions/command",
                      "concepts/actions/memory",
                      "concepts/actions/binance"
                    ]
                  }
                ]
              },
              "references/concepts/conditionals",
              "references/concepts/responses",
              "references/concepts/dynamic-content"
            ]
          },
          {
            "group": "References",
            "pages": ["references/configuration", "references/secrets"]
          }
        ]
      },
      {
        "tab": "Tutorials",
        "groups": [
          {
            "group": "Tutorials",
            "pages": ["tutorials/telegram-binance-bot"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "hidden": true,
        "groups": [
          {
            "group": "API Documentation",
            "pages": ["api-reference/introduction"]
          },
          {
            "group": "Endpoint Examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/logo-new.svg",
    "dark": "/logo/logo-white.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:contact@servflow.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dash.servflow.io"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/servflow"
    }
  }
}
